---
import BaseLayout from '@/layouts/BaseLayout.astro';

const { article } = Astro.props;
const date = article.data.published.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<BaseLayout title={article.data.title} description={article.data.description}>
  <article class="article-shell">
    <header class="article-header">
      <div class="meta-row">
        <span>{date}</span>
        {article.data.kind && <span>{article.data.kind}</span>}
        {article.data.readingTime && <span>{article.data.readingTime}</span>}
        {article.data.status === 'draft' && <span class="draft-badge">Draft</span>}
      </div>
      <h1>{article.data.title}</h1>
      <p>{article.data.description}</p>
      <div class="tag-row" aria-label="Tags">
        {article.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
      {article.data.hero && (
        <div class="hero-image">
          <img src={article.data.hero} alt="" loading="eager" />
        </div>
      )}
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
