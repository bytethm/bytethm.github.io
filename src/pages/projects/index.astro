---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Projects" description="Long-term projects and future subsites.">
  <section class="container listing">
    <div class="section-header">
      <div>
        <div class="eyebrow">Long-term Work</div>
        <h1>Projects</h1>
      </div>
      <p>独立维护的研究与写作项目。</p>
    </div>

    <article class="project-entry">
      <div>
        <div class="eyebrow">Research Library</div>
        <h2>Agent Research</h2>
        <p>
          从边界出发理解 Multi-Agent、子 Agent、上下文工程与运行时设计。
        </p>
      </div>
      <div class="project-actions">
        <a class="button primary" href="https://bytethm.github.io/agent-research/">Read research</a>
        <a class="button" href="https://github.com/bytethm/agent-research">Repository</a>
      </div>
    </article>
  </section>
</BaseLayout>
